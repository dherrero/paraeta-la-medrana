{
  "name": "nx-fullstack-starter",
  "version": "0.0.0",
  "license": "MIT",
  "author": {
    "name": "Daniel Herrero"
  },
  "engines": {
    "node": ">=24.14.1",
    "npm": ">=11.11.0"
  },
  "scripts": {
    "start": "npm run dev",
    "start:front": "nx serve front",
    "start:back": "cp .env.example apps/back/.env && nx serve back",
    "start:both": "concurrently --kill-others \"npm run start:front\" \"npm run start:back\"",
    "dev": "concurrently --kill-others \"npm run dev:db\" \"npm run dev:back\" \"npm run dev:front\"",
    "dev:db": "docker-compose -f docker-compose.db.yml up",
    "dev:back": "cp .env.example apps/back/.env && wait-on tcp:5432 && nx serve back",
    "dev:front": "wait-on tcp:3200 && nx serve front",
    "dev:db:down": "docker-compose -f docker-compose.db.yml down",
    "dev:db:clean": "docker-compose -f docker-compose.db.yml down -v",
    "clean": "nx reset && rm -fr tmp dist .angular",
    "build": "npm run build:front && npm run build:back",
    "build:front": "nx build front --skip-nx-cache",
    "build:back": "nx build back --skip-nx-cache",
    "docker:up": "npm run build && docker-compose up",
    "lint": "nx run-many -t lint",
    "lint:front": "nx lint front",
    "lint:back": "nx lint back",
    "lint:libs": "nx lint rest-dto",
    "lint:fix": "nx run-many -t lint --fix && npm run format",
    "lint:fix:front": "nx lint front --fix && npm run format:front",
    "lint:fix:back": "nx lint back --fix && npm run format:back",
    "lint:fix:libs": "nx lint rest-dto --fix && npm run format:libs",
    "format": "prettier --write \"**/*.{ts,js,json,html,scss,css,md}\"",
    "format:front": "prettier --write \"apps/front/**/*.{ts,js,json,html,scss,css}\"",
    "format:back": "prettier --write \"apps/back/**/*.{ts,js,json}\"",
    "format:libs": "prettier --write \"libs/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,html,scss,css,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:front": "vitest run --config apps/front/vitest.config.mts",
    "test:back": "vitest run --config apps/back/vitest.config.ts",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.4.10",
    "@analogjs/vitest-angular": "^2.4.10",
    "@angular-devkit/build-angular": "^21.2.8",
    "@angular-devkit/core": "^21.2.8",
    "@angular-devkit/schematics": "^21.2.8",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "^21.2.10",
    "@angular/language-service": "^21.2.10",
    "@angular/localize": "^21.2.10",
    "@nx/angular": "22.7.0",
    "@nx/esbuild": "22.7.0",
    "@nx/eslint": "22.7.0",
    "@nx/eslint-plugin": "22.7.0",
    "@nx/express": "22.7.0",
    "@nx/js": "22.7.0",
    "@nx/node": "22.7.0",
    "@nx/vite": "22.7.0",
    "@nx/web": "22.7.0",
    "@nx/webpack": "22.7.0",
    "@nx/workspace": "22.7.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.7",
    "@schematics/angular": "^21.2.8",
    "@svgr/webpack": "^8.0.1",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.30",
    "@swc/helpers": "~0.5.21",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.25.12",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.0.0",
    "happy-dom": "^20.0.8",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.4.0",
    "nx": "22.7.0",
    "prettier": "^3.8.3",
    "react-refresh": "^0.10.0",
    "ts-node": "10.9.1",
    "typescript": "^5.8.2",
    "@vitest/coverage-v8": "^4.0.8",
    "vitest": "^4.0.8",
    "wait-on": "^9.0.5",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@angular/animations": "^21.2.10",
    "@angular/common": "^21.2.10",
    "@angular/compiler": "^21.2.10",
    "@angular/core": "^21.2.10",
    "@angular/forms": "^21.2.10",
    "@angular/platform-browser": "^21.2.10",
    "@angular/platform-browser-dynamic": "^21.2.10",
    "@angular/router": "^21.2.10",
    "@ng-bootstrap/ng-bootstrap": "^20.0.0",
    "@jsverse/transloco": "^7.0.0",
    "@ngneat/until-destroy": "^10.0.0",
    "@popperjs/core": "^2.11.8",
    "axios": "^1.7.2",
    "bcrypt": "^6.0.0",
    "bootstrap": "^5.3.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "pdf-lib": "^1.3.1",
    "pdf-parse": "^2.4.5",
    "pdf2pic": "^3.1.1",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "rxjs": "^7.8.2",
    "sequelize": "^6.37.8",
    "tslib": "^2.8.1",
    "uuid": "^14.0.0",
    "zone.js": "^0.16.1"
  },
  "overrides": {
    "eslint-config-prettier": "^10.0.0",
    "express": "^5.2.1"
  },
  "lint-staged": {
    "apps/front/**/*.{ts,html}": [
      "prettier --write"
    ],
    "apps/back/**/*.ts": [
      "prettier --write"
    ],
    "libs/**/*.ts": [
      "prettier --write"
    ],
    "**/*.{json,md,css,scss}": [
      "prettier --write"
    ]
  }
}
